# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local

# raw crawl cache (large, resumable)
data/raw/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime / session state
.omx/
.playwright-mcp/

# scratch debug scripts (see AGENTS.md)
scripts/debug_*.ts
scripts/check_*.ts
scripts/eval_debug.ts
